# Copy this to .env and fill in your values:  cp .env.example .env

# ── AI Grading ───────────────────────────────────────────────────
# Claude Vision — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Ximilar card grading — https://app.ximilar.com
XIMILAR_API_KEY=

# ── eBay ─────────────────────────────────────────────────────────
# eBay Browse API — https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=

# ── Grading Cost ─────────────────────────────────────────────────
# Your PSA grading fee per card in USD
GRADING_FEE=25

# ── Email ────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_TO=you@example.com

# ── Google Sheets (optional) ─────────────────────────────────────
# Sheet ID from the URL: docs.google.com/spreadsheets/d/<ID>/edit
# Leave blank to skip
GOOGLE_SPREADSHEET_ID=
