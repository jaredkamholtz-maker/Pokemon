# ── Anthropic API (AI pre-filtering) ─────────────────────────────
# Used to filter ~3,000 discovered cards down to ~400 PSA-worthy candidates
# before scraping prices. Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── TCGPlayer API ────────────────────────────────────────────────
# Public Key and Private Key from your TCGPlayer developer portal.
# Find them at: https://developer.tcgplayer.com → Apps → your app
# (Do NOT use the "Authorize an App" page — that is for third-party access)
TCGPLAYER_PUBLIC_KEY=your_public_key_here
TCGPLAYER_PRIVATE_KEY=your_private_key_here

# ── Grading & Selling Parameters ────────────────────────────────
# PSA regular tier grading fee (USD). Check https://www.psacard.com/services/tradingcardgrading
GRADING_FEE=25.00

# Platform selling fee rate (decimal). TCGPlayer ~10% + ~3% payment = 0.13
SELLING_FEE_RATE=0.13

# ── Filter Thresholds ────────────────────────────────────────────
# Minimum ROI to surface a card (0.20 = 20%)
MIN_ROI=0.20

# Minimum gem rate (PSA 9+10 / total) to trust the data
MIN_GEM_RATE=0.30

# Minimum number of PSA submissions before gem rate is statistically meaningful
MIN_POP_COUNT=50

# Maximum raw card price you are willing to pay (USD)
MAX_RAW_PRICE=500.00

# When population data is unavailable, surface cards where the breakeven
# gem rate (minimum % of submissions that must grade PSA9/10 for profit) is
# below this threshold. 0.15 = card is profitable if ≥15% grade gem.
MAX_BREAKEVEN_GEM_RATE=0.15

# ── Google Sheets Output ─────────────────────────────────────────
# Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<ID>/edit
# Leave blank to skip Sheets output
GOOGLE_SPREADSHEET_ID=

# ── Email Notifications ──────────────────────────────────────────
# SMTP server for sending opportunity emails (e.g. smtp.gmail.com)
# For Gmail: use App Password (not your account password)
# Leave blank to skip email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
# Comma-separated to send to multiple recipients (e.g. you + a client)
EMAIL_TO=you@example.com,client@example.com
